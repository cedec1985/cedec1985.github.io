{
  "extends": [
    "development"
  ],
  "hints": {
    "axe/forms": [
      "default",
      {
        "label": "off"
      }
    ],
    "compat-api/css": "off",
    "meta-viewport": "off",
    "axe/structure": [
      "default",
      {
        "list": "off",
        "listitem": "off"
      }
    ],
    "no-inline-styles": "off",
    "axe/text-alternatives": "off",
    "compat-api/html": [
      "default",
      {
        "ignore": [
          "meta[name=theme-color]",
          "tool-tip[popover]",
          "button[autocapitalize]"
        ]
      }
    ],
    "axe/language": [
      "default",
      {
        "html-lang-valid": "off"
      }
    ],
    "meta-charset-utf-8": "off",
    "apple-touch-icons": "off",
    "disown-opener": "off"
  }
}