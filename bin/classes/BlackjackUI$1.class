   private void distributeInitialCards() {
      this.playerHand.clear();
      this.dealerHand.clear();

      for(int i = 0; i < 6; ++i) {
         this.playerLabels[i].setIcon((Icon)null);
         this.dealerLabels[i].setIcon((Icon)null);
      }

      this.playerHand.add(this.deck.drawCard());
      this.playerHand.add(this.deck.drawCard());
      this.dealerHand.add(this.deck.drawCard());
      this.dealerHand.add(this.deck.drawCard());
      this.updateHandsDisplay(false);
      this.updateScoreLabels(false);
      this.statusLabel.setText("À vous de jouer !");
   }

   private void updateHandsDisplay(boolean showDealerAll) {
      int i;
      for(i = 0; i < this.playerHand.size(); ++i) {
         this.playerLabels[i].setIcon(((Card)this.playerHand.get(i)).getImage());
      }

      for(i = 0; i < this.dealerHand.size(); ++i) {
         if (i != 0 && !showDealerAll) {
            this.dealerLabels[i].setIcon(new ImageIcon("classes/Blackjack copy.jpg"));
         } else {
            this.dealerLabels[i].setIcon(((Card)this.dealerHand.get(i)).getImage());
         }
      }

   }

   private void updateScoreLabels(boolean showDealerAll) {
      int playerScore = this.calculateScore(this.playerHand);
      int dealerScore = this.calculateScore(this.dealerHand);
      this.playerScoreLabel.setText("Score joueur : " + playerScore);
      this.dealerScoreLabel.setText("Score dealer : " + (showDealerAll ? dealerScore : "?"));
   }

   private void hit() {
      if (this.playerHand.size() < 6) {
         this.playerHand.add(this.deck.drawCard());
         this.updateHandsDisplay(false);
         this.updateScoreLabels(false);
         int score = this.calculateScore(this.playerHand);
         if (score > 21) {
            ++this.losses;
            this.endRound("\ud83d\udca5 Vous avez dépassé 21 ! Vous perdez \ud83d\ude22");
         }
      }

   }

   private void stand() {
      while(this.calculateScore(this.dealerHand) < 17) {
         this.dealerHand.add(this.deck.drawCard());
      }

      this.updateHandsDisplay(true);
      this.updateScoreLabels(true);
      int playerScore = this.calculateScore(this.playerHand);
      int dealerScore = this.calculateScore(this.dealerHand);
      if (dealerScore <= 21 && playerScore <= dealerScore) {
         if (dealerScore == playerScore) {
            ++this.ties;
            this.endRound(" Égalité (" + playerScore + ")");
         } else {
            ++this.losses;
            this.endRound(" Le dealer gagne (" + dealerScore + " contre " + playerScore + ")");
         }
      } else {
         ++this.wins;
         this.endRound(" Vous gagnez ! (" + playerScore + " contre " + dealerScore + ")");
      }

   }

   private void restartGame() {
      this.playerHand.clear();
      this.dealerHand.clear();
      this.deck.shuffle();
      this.distributeInitialCards();
      this.hitButton.setEnabled(true);
      this.standButton.setEnabled(true);
      this.statusLabel.setText("Nouvelle manche ! À vous de jouer.");
      this.updateStats();
   }

   private void endRound(String message) {
      this.updateHandsDisplay(true);
      this.updateScoreLabels(true);
      this.statusLabel.setText(message);
      this.hitButton.setEnabled(false);
      this.standButton.setEnabled(false);
      this.updateStats();
   }

   private void updateStats() {
      this.label.setText(this.getStatsText());
   }

   private String getStatsText() {
      return "<html><center><b>Statistiques </b><br>Victoires : " + this.wins + "<br>" + "Défaites : " + this.losses + "<br>" + "Égalités : " + this.ties + "</center></html>";
   }

   private JLabel createImageBorder() {
      this.label.setFont(new Font("Arial", 1, 18));
      Border blueline = BorderFactory.createLineBorder(Color.green);
      TitledBorder title = BorderFactory.createTitledBorder(blueline, "statistiques");
      title.setTitleJustification(2);
      this.label.setBorder(title);
      this.label.setOpaque(true);
      this.label.setBackground(Color.YELLOW);
      this.label.setLabelFor(this.statusLabel);
      this.updateStats();
      this.getContentPane().add(this.label);
      return this.label;
   }

   private int calculateScore(List<Card> hand) {
      int total = 0;
      int aceCount = 0;
      Iterator var5 = hand.iterator();

      while(var5.hasNext()) {
         Card c = (Card)var5.next();
         total += c.getValue();
         if (c.getRank().equals("A")) {
            ++aceCount;
         }
      }

      while(total > 21 && aceCount > 0) {
         total -= 10;
         --aceCount;
      }

      return total;
   }

   private void newMenuItemActionPerformed(ActionEvent e) {
      this.restartGame();
   }

   private void exitForm(WindowEvent evt) {
      System.exit(0);
   }

   private void exitMenuItemActionPerformed(ActionEvent e) {
      System.exit(0);
   }

   public static void changeSize(String inImg, String outImg, int w, int h) throws IOException {
      File f = new File(inImg);
      BufferedImage inputImage = ImageIO.read(f);
      BufferedImage img = new BufferedImage(w, h, inputImage.getType());
      Graphics2D g = img.createGraphics();
      g.drawImage(inputImage, 0, 0, w, h, (ImageObserver)null);
      g.dispose();
      String name = outImg.substring(outImg.lastIndexOf(".") + 1);
      ImageIO.write(img, name, new File(outImg));
   }

